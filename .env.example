# Umami Analytics (Client-side)
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# Umami API (Server-side for Trending Graphs)
# For Umami Cloud: use a Bearer token
UMAMI_API_TOKEN=
UMAMI_API_URL=https://api.umami.is

# For Self-hosted Umami: use Client ID (Username) and Secret (Password)
UMAMI_API_CLIENT_ID=
UMAMI_API_CLIENT_SECRET=
